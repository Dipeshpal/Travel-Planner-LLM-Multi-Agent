# ===========================
# Search Provider Configuration
# ===========================
# Choose between "firecrawl" or "brave"
SEARCH_PROVIDER="firecrawl"

# Firecrawl API Key
# Get from: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=""

# Brave Search API Key
# Get from: https://api.search.brave.com/
BRAVE_API_KEY=""

# ===========================
# LLM Model Configuration
# ===========================
# LiteLLM supports multiple providers
# Format: provider/model-name or openrouter/provider/model-name

# Examples:
# --------
# GROQ Models:
#   - groq/deepseek-r1-distill-llama-70b
#   - groq/mixtral-8x7b-32768
#   - groq/llama-3.3-70b-versatile
#   - groq/openai/gpt-oss-120b
#
# Google Gemini Models:
#   - gemini/gemini-2.0-flash
#   - gemini/gemini-1.5-pro
#
# OpenRouter Models (aggregates multiple providers):
#   - openrouter/openai/gpt-4o-mini
#   - openrouter/anthropic/claude-3.5-sonnet
#   - openrouter/google/gemini-2.0-flash-lite-preview-01-15
#   - openrouter/meta-llama/llama-3.3-70b-instruct
#
# OpenAI Models:
#   - openai/gpt-4o
#   - openai/gpt-4-turbo
#   - openai/gpt-3.5-turbo

LLM_MODEL="groq/openai/gpt-oss-120b"

# ===========================
# LLM Provider API Keys
# ===========================
# Set the API key for your chosen LLM provider

# Groq API Key
# Get from: https://console.groq.com/keys
GROQ_API_KEY=""

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=""

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ===========================
# Authentication
# ===========================
# Password for "Use Password" login method
PASSWORD="your_secure_password_here"
